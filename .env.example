# Database
POSTGRES_USER=opencut
POSTGRES_PASSWORD=opencut
POSTGRES_DB=opencut
DATABASE_URL=postgresql://opencut:opencut@db:5432/opencut

# Redis via HTTP adapter
UPSTASH_REDIS_REST_URL=http://serverless-redis-http:80
UPSTASH_REDIS_REST_TOKEN=upstash_redis_example_token
SRH_TOKEN=srh_redis_example_token

# Authentication (generate a strong random string - REQUIRED for production)
BETTER_AUTH_SECRET=your_long_random_secret_here_at_least_32_characters

# Public URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3100
NEXT_PUBLIC_MARBLE_API_URL=https://api.marblecms.com

# Marble CMS
MARBLE_WORKSPACE_KEY=your_workspace_key_here

# Freesound API
FREESOUND_CLIENT_ID=your_client_id_here
FREESOUND_API_KEY=your_api_key_here

# Ports (optional - override in docker-compose or here)
WEB_PORT=3100

# Custom volume mounts (host:container format)
# On Windows 11 + Docker Desktop (WSL2): use /mnt/c/Users/... paths
# On Dokploy (Linux): use absolute Linux paths
# Leave empty to disable (defaults to harmless /tmp dummy mount)
# MOUNT_0=app data (defaults to ./data:/app/data)
# MOUNT_1=/mnt/c/Users/default/projects:/projects
# MOUNT_2=/mnt/c/Users/default/working-files:/working-files
# MOUNT_3=
# MOUNT_4=
# MOUNT_5=
